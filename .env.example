# Server
PORT=8080
SESSION_SECRET=change-this-to-a-long-random-string
ADMIN_PASSWORD=change-this-admin-password
ADMIN_GITHUB_USERNAMES=your-github-username
# Optional API token for script/admin endpoint auth without session cookie
ADMIN_API_KEY=change-this-admin-api-key

# Site URL used for Stripe checkout redirects
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase (optional)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (server-only secrets)
STRIPE_SECRET_KEY=sk_test_xxx
# Stripe webhook secret from: Dashboard > Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Printful (server-only secret)
PRINTFUL_API_TOKEN=pfu_xxx
# Optional alias if you want to keep multiple tokens during rotation
# PRINTFUL_API_TOKEN_LORGENINV=pfu_xxx
# Optional OAuth token (required by some Printful endpoints)
# PRINTFUL_OAUTH_TOKEN=pfu_oauth_xxx
# Optional when account has multiple stores
# PRINTFUL_STORE_ID=12345678
