# Server
PORT=8080
SESSION_SECRET=change-this-to-a-long-random-string
ADMIN_PASSWORD=change-this-admin-password
ADMIN_GITHUB_USERNAMES=your-github-username

# Site URL used for Stripe checkout redirects
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase (optional)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (server-only secrets)
STRIPE_SECRET_KEY=sk_test_xxx
# Stripe webhook secret from: Dashboard > Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Printify (server-only secret)
PRINTIFY_API_TOKEN=printify_pat_xxx
# Optional alias if you want to keep multiple tokens during rotation
# PRINTIFY_API_TOKEN_LORGENINV=printify_pat_xxx

# Optional default shop id for manual SQL/product setup
# PRINTIFY_SHOP_ID=1234567
